# Landy API 서버 베이스 URL (브라우저에 노출되므로 NEXT_PUBLIC_ 접두사 필수)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- Kakao OAuth (서버 전용 — 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것) ---
# Kakao 개발자 콘솔의 REST API 키 (authorize + 토큰 교환의 client_id)
KAKAO_REST_API_KEY=
# Kakao 콘솔에서 "Client Secret"을 활성화한 경우에만 설정 (선택)
KAKAO_CLIENT_SECRET=
# Kakao 앱에 등록한 Redirect URI와 정확히 일치해야 함
# 로컬: http://localhost:3000/auth/kakao/callback
# 운영: https://<admin-host>/auth/kakao/callback
KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback
